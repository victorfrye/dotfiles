{
  "mcpServers": {
    "aspire": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "aspire",
      "args": [
        "mcp",
        "start"
      ]
    },
    "playwright": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {},
      "tools": [
        "query-docs",
        "resolve-library-id"
      ]
    },
    "winget": {
      "type": "stdio",
      "command": "WindowsPackageManagerMCPServer.exe",
      "tools": [
        "*"
      ],
      "args": []
    }
  }
}
